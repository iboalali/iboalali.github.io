---
title: Ibrahim Al-Alali
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <title>{{ title }}</title>
        <meta name="description" content="Ibrahim Al-Alali is an Android app software developer">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">    
        <meta name="keywords" content="ibrahim, al-alali, ibrahim al-alali, alali, ibo, apps, app, play store, notification, java, kotlin">
        <meta name="language" content="English">
        <meta name="supported-color-schemes" content="dark light">
        <link rel="stylesheet" type="text/css" href="/media/styles.css">
        <script>
            (function() {
                var t = localStorage.getItem('theme');
                if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
            })();
        </script>
        <link rel="icon" type="image/png" href="/media/icon_x32.png" sizes="32x32">
        <link rel="icon" type="image/png" href="/media/icon_x64.png" sizes="64x64">
        <link rel="icon" type="image/png" href="/media/icon_x128.png" sizes="128x128">
        <!--[if lte IE 8]>
        <script>
        document.createElement('main'); 
        document.createElement('nav'); 
        </script>
        <![endif]-->
        <!-- Analytics: TelemetryDeck -->
        <script
            src="https://cdn.telemetrydeck.com/websdk/telemetrydeck.min.js"
            data-app-id="2D083718-D442-4A8E-B797-68F24ADD0C7E"
        ></script>
        <!-- Open Graph card -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content="{{ title }}" />
        <meta property="og:description" content="Ibrahim Al-Alali is an Android app software developer" />
        <meta property="og:image" content="https://gravatar.com/avatar/c986ffd7d07a2ae1336d5321ae0c6392?size=500" />
        <meta property="og:image:width" content="400" />
        <meta property="og:image:height" content="400" />
        <meta name="og:image:alt" content="Ibrahim's profile photo" />
    </head>

    <body>
        <nav>
            <ul>
                <li>
                    {% if page.url == "/" %}<span class="nav-current">Home</span>{% else %}<a href="/">Home</a>{% endif %}
                </li>
                <li>
                    {% if page.url == "/about/" %}<span class="nav-current">About</span>{% else %}<a href="/about">About</a>{% endif %}
                </li>
                <li>
                    {% if page.url == "/contact/" %}<span class="nav-current">Contact</span>{% else %}<a href="/contact">Contact</a>{% endif %}
                </li>
                <li>
                    {% if page.url == "/privacy/" %}<span class="nav-current">Privacy</span>{% else %}<a href="/privacy">Privacy</a>{% endif %}
                </li>
            </ul>
        </nav>

        <main>
            {{ content | safe }}
        </main>

        <footer class="site-footer">
            <a href="https://github.com/iboalali/iboalali.github.io" target="_blank" rel="noopener" class="site-footer-link">View this site's source on GitHub</a>
        </footer>

        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode"></button>
        <span class="theme-toggle-tooltip" id="theme-toggle-tooltip" role="status" aria-live="polite"></span>

        <!-- Main script -->
        <script src="/main.js" ></script>
        <!-- Mastodon verification -->
        <a href="https://mastodon.social/@iboalali" rel="me" style="display:none">My Mastodon</a>
    </body>
</html>